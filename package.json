{
  "name": "axim-ground-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:serve": "vite build && vite preview --port 5173 --strictPort",
    "e2e": "start-server-and-test test:serve http://127.0.0.1:5173 'python3 jules-scratch/verification/verify_login.py'",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "db:migrate": "cd server && npm run db:migrate",
    "start:all": "concurrently \"npm run server:dev\" \"npm run dev\""
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mapbox/mapbox-gl-draw": "^1.5.0",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@playwright/test": "^1.56.1",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.7.2",
    "framer-motion": "^11.18.2",
    "mapbox-gl": "^3.5.1",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.2.1",
    "react-map-gl": "^7.1.9",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.24.1",
    "recharts": "^2.15.4",
    "use-control": "^0.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "0.4.9",
    "globals": "^15.8.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.39",
    "start-server-and-test": "^2.1.2",
    "tailwindcss": "^3.4.6",
    "ts-jest": "^29.4.5",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
