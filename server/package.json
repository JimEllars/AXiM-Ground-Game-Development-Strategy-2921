{
  "name": "axim-ground-game-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run start",
    "build": "rm -rf dist && tsc",
    "start": "node dist/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "start:test": "tsx src/server.ts",
    "db:migrate": "node dist/scripts/migrate.js",
    "db:seed": "npm run build && node dist/services/seedDatabase.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.86.0",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "papaparse": "^5.4.1",
    "pg": "^8.12.0",
    "wellknown": "^0.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.25",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.14.10",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/wellknown": "^0.5.8",
    "jest": "^29.7.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
